{
  "expo": {
    "name": "Kunal Enterprises",
    "slug": "kunal-enterprises-mobile",
    "scheme": "kunalenterprises",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amol909.kunal-enterprises-mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.amol909.kunalenterprisesmobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "backgroundColor": "#ffffff",
          "imageWidth": 100
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9e0b149f-f450-4b19-a90c-19901515e619"
      }
    }
  }
}
